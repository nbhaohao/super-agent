{
  "name": "super-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "agent": "tsx --env-file-if-exists=.env src/cli.ts",
    "dev": "tsx watch src/cli.ts",
    "start": "tsx src/cli.ts",
    "verify": "vitest run",
    "v": "vitest run -t",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "v:s1": "tsx --env-file-if-exists=.env src/_smoke/s1-chat.ts",
    "v:s2": "tsx --env-file-if-exists=.env src/_smoke/s2-loop.ts",
    "v:s3": "tsx --env-file-if-exists=.env src/_smoke/s3-fuses.ts",
    "v:s4": "tsx --env-file-if-exists=.env src/_smoke/m02-tools.ts",
    "v:s5": "tsx --env-file-if-exists=.env src/_smoke/m02-tools.ts",
    "v:s6": "tsx --env-file-if-exists=.env src/_smoke/m02-tools.ts",
    "v:s7": "tsx --env-file-if-exists=.env src/_smoke/m02-tools.ts",
    "v:s8": "tsx --env-file-if-exists=.env src/_smoke/m02-tools.ts",
    "v:s9": "tsx --env-file-if-exists=.env src/_smoke/m02-tools.ts",
    "v:s10": "tsx --env-file-if-exists=.env src/_smoke/m03-context.ts 10",
    "v:s11": "tsx --env-file-if-exists=.env src/_smoke/m03-context.ts 11",
    "v:s12": "tsx --env-file-if-exists=.env src/_smoke/m03-context.ts 12",
    "v:s13": "tsx --env-file-if-exists=.env src/_smoke/m03-context.ts 13",
    "v:s14": "tsx --env-file-if-exists=.env src/_smoke/m04-memory.ts 14",
    "v:s15": "tsx --env-file-if-exists=.env src/_smoke/m04-memory.ts 15",
    "v:s16": "tsx --env-file-if-exists=.env src/_smoke/m04-memory.ts 16"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2",
    "@ai-sdk/openai": "^2",
    "@ai-sdk/provider": "^2",
    "ai": "^5",
    "dotenv": "^16"
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^3"
  }
}
